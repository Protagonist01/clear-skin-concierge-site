# Clear Skin AI Suite - OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=12000
OPENROUTER_MAX_ATTEMPTS=1

# Concierge embeddings - OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_MS=5000
# Optional. Leave blank to use the model's native 1536 dimensions.
OPENAI_EMBEDDING_DIMENSIONS=

# Optional attribution headers for OpenRouter analytics
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Clear Skin Site

# Concierge cost controls
CONCIERGE_MAX_REPLY_TOKENS=500
CONCIERGE_TOOL_TURN_MAX_TOKENS=350
CONCIERGE_CONTEXT_TURNS=4
CONCIERGE_MESSAGE_CHAR_LIMIT=1200
CONCIERGE_RATE_LIMIT_PER_MINUTE=6
CONCIERGE_DAILY_REQUEST_LIMIT=40
CONCIERGE_DAILY_SPEND_LIMIT_USD=0.25
CONCIERGE_PROMPT_TOKEN_USD_PER_1K=0.001
CONCIERGE_COMPLETION_TOKEN_USD_PER_1K=0.002
CONCIERGE_SEMANTIC_CACHE_ENABLED=true
CONCIERGE_SEMANTIC_CACHE_TTL_HOURS=24
CONCIERGE_SEMANTIC_CACHE_THRESHOLD=0.92
CONCIERGE_FORCE_MODEL_COMPOSER=false
CONCIERGE_COOKIE_SECRET=
CONCIERGE_DIAGNOSTICS_TOKEN=

# Concierge vector database - Pinecone
PINECONE_API_KEY=your_pinecone_api_key
# Use the index host from Pinecone, for example: https://your-index-name-xxxx.svc.region.pinecone.io
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=clear-skin-concierge
PINECONE_CACHE_NAMESPACE=clear-skin-concierge-cache
PINECONE_TIMEOUT_MS=5000
# Keep false in live chat. Run the seed script explicitly when business knowledge changes.
PINECONE_AUTO_SEED=false

# Booking handoff
# Leave blank to use the built-in /book flow. Use a Calendly event URL to hand off externally.
CALENDLY_SCHEDULING_URL=
NEXT_PUBLIC_CALENDLY_URL=

# Clear Skin Email Nurture System - Resend
RESEND_API_KEY=your_resend_api_key
SITE_URL=http://localhost:3000
CLEAR_SKIN_FROM_EMAIL=Clear Skin <onboarding@resend.dev>
CLEAR_SKIN_SUPPORT_EMAIL=support@clearskin.com

# Clear Skin operational data
CLEAR_SKIN_DB_PATH=./data/clear-skin.sqlite
CLEAR_SKIN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
CLEAR_SKIN_SCHEDULING_WEBHOOK_URL=
CLEAR_SKIN_SCHEDULING_API_KEY=

# Public social profiles
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
